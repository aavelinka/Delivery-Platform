JWT_SECRET_KEY=replace-with-a-long-random-secret
GATEWAY_INTERNAL_SECRET=replace-with-a-different-long-random-secret
AUTH_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
AUTH_BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-long-random-admin-password
AUTH_BOOTSTRAP_ADMIN_FULL_NAME=Platform Administrator

# Optional OpenTelemetry trace export
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_EXPORTER_OTLP_TIMEOUT=10
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Optional Kafka consumer reliability overrides
ORDER_KAFKA_CONSUMER_MAX_RETRIES=3
ORDER_KAFKA_CONSUMER_RETRY_BACKOFF_SECONDS=1
ORDER_KAFKA_CONSUMER_DLQ_TOPIC=order-service.dlq
COURIER_KAFKA_CONSUMER_MAX_RETRIES=3
COURIER_KAFKA_CONSUMER_RETRY_BACKOFF_SECONDS=1
COURIER_KAFKA_CONSUMER_DLQ_TOPIC=courier-service.dlq
TRACKING_KAFKA_CONSUMER_MAX_RETRIES=3
TRACKING_KAFKA_CONSUMER_RETRY_BACKOFF_SECONDS=1
TRACKING_KAFKA_CONSUMER_DLQ_TOPIC=tracking-service.dlq
NOTIFICATION_KAFKA_CONSUMER_MAX_RETRIES=3
NOTIFICATION_KAFKA_CONSUMER_RETRY_BACKOFF_SECONDS=1
NOTIFICATION_KAFKA_CONSUMER_DLQ_TOPIC=notification-service.dlq

# Optional Docker Compose host port overrides
API_GATEWAY_HOST_PORT=8080
AUTH_SERVICE_HOST_PORT=8003
ORDER_SERVICE_HOST_PORT=8000
COURIER_SERVICE_HOST_PORT=8001
NOTIFICATION_SERVICE_HOST_PORT=8002
USER_SERVICE_HOST_PORT=8004
TRACKING_SERVICE_HOST_PORT=8005
ADMIN_SERVICE_HOST_PORT=8006
PAYMENT_SERVICE_HOST_PORT=8007
OTEL_COLLECTOR_OTLP_GRPC_HOST_PORT=4317
OTEL_COLLECTOR_OTLP_HTTP_HOST_PORT=4318
PROMETHEUS_HOST_PORT=9090
GRAFANA_HOST_PORT=3000
JAEGER_UI_HOST_PORT=16686
