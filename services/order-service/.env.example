ORDER_SERVICE_NAME=order-service
ORDER_ENVIRONMENT=local
ORDER_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/orders
ORDER_KAFKA_ENABLED=true
ORDER_KAFKA_BOOTSTRAP_SERVERS=localhost:29092
ORDER_KAFKA_CLIENT_ID=order-service
ORDER_KAFKA_GROUP_ID=order-service
ORDER_KAFKA_ORDERS_TOPIC=orders.events
ORDER_KAFKA_COURIERS_TOPIC=couriers.events
ORDER_JWT_SECRET_KEY=replace-with-a-long-random-secret
ORDER_JWT_ALGORITHM=HS256
ORDER_GATEWAY_INTERNAL_SECRET=replace-with-a-different-long-random-secret
ORDER_CORS_ORIGINS=["*"]
