COURIER_SERVICE_NAME=courier-service
COURIER_ENVIRONMENT=local
COURIER_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5433/couriers
COURIER_KAFKA_ENABLED=true
COURIER_KAFKA_BOOTSTRAP_SERVERS=localhost:29092
COURIER_KAFKA_CLIENT_ID=courier-service
COURIER_KAFKA_GROUP_ID=courier-service
COURIER_KAFKA_COURIERS_TOPIC=couriers.events
COURIER_KAFKA_ORDERS_TOPIC=orders.events
COURIER_JWT_SECRET_KEY=replace-with-a-long-random-secret
COURIER_JWT_ALGORITHM=HS256
COURIER_GATEWAY_INTERNAL_SECRET=replace-with-a-different-long-random-secret
COURIER_CORS_ORIGINS=["*"]
