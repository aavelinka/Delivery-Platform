GATEWAY_SERVICE_NAME=api-gateway
GATEWAY_ENVIRONMENT=local
GATEWAY_JWT_SECRET_KEY=replace-with-a-long-random-secret
GATEWAY_JWT_ALGORITHM=HS256
GATEWAY_INTERNAL_SECRET=replace-with-a-different-long-random-secret
GATEWAY_AUTH_SERVICE_URL=http://localhost:8003
GATEWAY_ORDER_SERVICE_URL=http://localhost:8000
GATEWAY_COURIER_SERVICE_URL=http://localhost:8001
GATEWAY_NOTIFICATION_SERVICE_URL=http://localhost:8002
GATEWAY_USER_SERVICE_URL=http://localhost:8004
GATEWAY_TRACKING_SERVICE_URL=http://localhost:8005
GATEWAY_REQUEST_TIMEOUT_SECONDS=30
GATEWAY_RETRY_ATTEMPTS=2
GATEWAY_RETRY_BACKOFF_SECONDS=0.2
GATEWAY_RATE_LIMIT_REQUESTS=120
GATEWAY_RATE_LIMIT_WINDOW_SECONDS=60
