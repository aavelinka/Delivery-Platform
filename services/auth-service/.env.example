AUTH_SERVICE_NAME=auth-service
AUTH_ENVIRONMENT=local
AUTH_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5435/auth
AUTH_SECRET_KEY=replace-with-a-long-random-secret
AUTH_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=30
AUTH_REFRESH_TOKEN_EXPIRE_DAYS=30
AUTH_GATEWAY_INTERNAL_SECRET=replace-with-a-different-long-random-secret
AUTH_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
AUTH_BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-long-random-admin-password
AUTH_BOOTSTRAP_ADMIN_FULL_NAME=Platform Administrator
AUTH_CORS_ORIGINS=["*"]
