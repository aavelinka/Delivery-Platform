TRACKING_SERVICE_NAME=tracking-service
TRACKING_ENVIRONMENT=local
TRACKING_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5437/tracking
TRACKING_KAFKA_ENABLED=true
TRACKING_KAFKA_BOOTSTRAP_SERVERS=localhost:29092
TRACKING_KAFKA_CLIENT_ID=tracking-service
TRACKING_KAFKA_GROUP_ID=tracking-service
TRACKING_KAFKA_TOPIC=tracking.events
TRACKING_KAFKA_ORDERS_TOPIC=orders.events
TRACKING_JWT_SECRET_KEY=replace-with-a-long-random-secret
TRACKING_JWT_ALGORITHM=HS256
TRACKING_GATEWAY_INTERNAL_SECRET=replace-with-a-different-long-random-secret
TRACKING_CORS_ORIGINS=["*"]
