NOTIFICATION_SERVICE_NAME=notification-service
NOTIFICATION_ENVIRONMENT=local
NOTIFICATION_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5434/notifications
NOTIFICATION_KAFKA_ENABLED=true
NOTIFICATION_KAFKA_BOOTSTRAP_SERVERS=localhost:29092
NOTIFICATION_KAFKA_CLIENT_ID=notification-service
NOTIFICATION_KAFKA_GROUP_ID=notification-service
NOTIFICATION_KAFKA_TOPICS=["orders.events","couriers.events","tracking.events"]
NOTIFICATION_JWT_SECRET_KEY=replace-with-a-long-random-secret
NOTIFICATION_JWT_ALGORITHM=HS256
NOTIFICATION_GATEWAY_INTERNAL_SECRET=replace-with-a-different-long-random-secret
NOTIFICATION_CORS_ORIGINS=["*"]
